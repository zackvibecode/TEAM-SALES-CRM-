# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Marketing: WhatsApp or email for pricing CTAs (Hubungi Sales)
NEXT_PUBLIC_SALES_CONTACT_URL=https://wa.me/60XXXXXXXXX

# Public CRM URL for AI agents (use custom domain, not *.vercel.app preview)
NEXT_PUBLIC_CRM_BASE_URL=https://salescrm.zaqone.com

# Optional fallback API key (prefer Admin → AI API Key in dashboard)
# Send as: X-API-Key, Authorization: Bearer, or ?api_key= on URL
CRM_API_KEY=
