# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Marketing: WhatsApp or email for pricing CTAs (Hubungi Sales)
NEXT_PUBLIC_SALES_CONTACT_URL=https://wa.me/60XXXXXXXXX

# Optional fallback API key (prefer generating from Admin → Settings → AI API Key)
# Send as: X-API-Key: your_key  OR  Authorization: Bearer your_key
CRM_API_KEY=
